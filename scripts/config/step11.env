# --------------------------------------------------------------------
# STEP11 Desktop Tools
# --------------------------------------------------------------------

IMAGE_NAME=desktop-tools-microvm-demo-v1
IMAGE_VERSION=1.0

STEP_DIR=step11-desktop-tools
ZIP_NAME=step11-desktop-tools-v1.zip

# Default page opened by run.sh
TARGET_PORT=6080
URL=/vnc.html

# Services

# noVNC
VNC_PORT=6080

# ttyd
TERMINAL_PORT=7681

# code-server
CODE_SERVER_PORT=8081

# Desktop Tools
DISPLAY=:1
ARTIFACT_DIR=/root/artifacts
WORKSPACE_DIR=/root/workspace

# MicroVM Auth Token
ALLOWED_PORTS_JSON='[
  {"port":6080},
  {"port":7681},
  {"port":8081}
]'