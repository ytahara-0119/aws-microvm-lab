# --------------------------------------------------------------------
# STEP10 Desktop Agent
# --------------------------------------------------------------------

IMAGE_NAME=desktop-agent-microvm-demo-v2
IMAGE_VERSION=1.0

STEP_DIR=step10-desktop-agent
ZIP_NAME=step10-desktop-agent-v2.zip

# Default page opened by run.sh
TARGET_PORT=6080
URL=/vnc.html

# Services

# noVNC
VNC_PORT=6080

# ttyd
TERMINAL_PORT=7681

# code-server
CODE_SERVER_PORT=8081

# Desktop Agent
DISPLAY=:1
ARTIFACT_DIR=/root/artifacts

# MicroVM Auth Token
ALLOWED_PORTS_JSON='[
  {"port":6080},
  {"port":7681},
  {"port":8081}
]'
