# --------------------------------------------------------------------
# Common Configuration
# --------------------------------------------------------------------

# 名前・ZIPの世代。各STEPで上書き可能
IMAGE_VERSION=1.0

# AWS MicroVM Image内部のバージョン
# create-microvm-imageで新規作成した場合は通常1.0
MICROVM_IMAGE_VERSION=1.0

# Default page
TARGET_PORT=6080
URL=/vnc.html

# Services
VNC_PORT=6080
TERMINAL_PORT=7681
CODE_SERVER_PORT=8081

# Desktop
DISPLAY=:1
ARTIFACT_DIR=/root/artifacts
WORKSPACE_DIR=/root/workspace

# MicroVM Auth Token
ALLOWED_PORTS_JSON='[
  {"port":6080},
  {"port":7681},
  {"port":8081}
]'